# LiveKit — audio transport
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Deepgram — STT
DEEPGRAM_API_KEY=

# OpenAI — GPT-4o brain
OPENAI_API_KEY=

# Cartesia — TTS
CARTESIA_API_KEY=
# Default voice for English and any language without a specific override.
CARTESIA_VOICE_ID=
# Optional per-language voice overrides. Named CARTESIA_VOICE_ID_<LANG>
# where <LANG> is the ISO-639-1 code in uppercase (ES, ZH, FR, DE, ...).
# Leave blank to fall back to CARTESIA_VOICE_ID for all languages.
CARTESIA_VOICE_ID_ES=
CARTESIA_VOICE_ID_ZH=

# Tavus — conversational avatar
TAVUS_API_KEY=
# Stock replica default: r5f0577fc829 (Lucas - Studio). Swap with custom Replica ID when ready.
TAVUS_REPLICA_ID=r5f0577fc829
# Optional: Tavus persona ID. Omit to drive behavior via conversational_context only.
# Create a cashier persona with POST https://tavusapi.com/v2/personas and paste the ID here.
TAVUS_PERSONA_ID=

# Public app URL — used for QR deep links + CORS
NEXT_PUBLIC_APP_URL=
